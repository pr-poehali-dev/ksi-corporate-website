{
  "tests": [
    {
      "name": "OPTIONS returns CORS headers",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200,
      "bodyMatcher": "partial",
      "expectedBody": {}
    },
    {
      "name": "GET method not allowed",
      "method": "GET",
      "path": "/",
      "expectedStatus": 405,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "Method not allowed"}
    },
    {
      "name": "POST without body returns validation error for name",
      "method": "POST",
      "path": "/",
      "body": {},
      "expectedStatus": 400,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "Поле 'name' обязательно"}
    },
    {
      "name": "POST with name but no email returns validation error",
      "method": "POST",
      "path": "/",
      "body": {"name": "Тест"},
      "expectedStatus": 400,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "Поле 'email' обязательно"}
    },
    {
      "name": "POST valid contact form returns success",
      "method": "POST",
      "path": "/",
      "body": {
        "name": "Иван Иванов",
        "org": "ООО Тест",
        "email": "test@example.com",
        "role": "developer",
        "message": "Тестовое сообщение"
      },
      "expectedStatus": 200,
      "bodyMatcher": "partial",
      "expectedBody": {"success": true, "message": "Обращение отправлено"}
    },
    {
      "name": "POST contact form with phone and messengers returns success",
      "method": "POST",
      "path": "/",
      "body": {
        "name": "Пётр Петров",
        "email": "petr@example.com",
        "phone": "+7 999 123 45 67",
        "messengers": ["telegram", "whatsapp"],
        "role": "investor",
        "message": "Свяжитесь со мной"
      },
      "expectedStatus": 200,
      "bodyMatcher": "partial",
      "expectedBody": {"success": true, "message": "Обращение отправлено"}
    },
    {
      "name": "POST test-telegram without auth returns 403",
      "method": "POST",
      "path": "/",
      "body": {"action": "test"},
      "expectedStatus": 403,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "Access denied. Internal user required."}
    },
    {
      "name": "POST test-telegram with invalid token returns 403",
      "method": "POST",
      "path": "/",
      "headers": {"X-Authorization": "Bearer invalidtoken999"},
      "body": {"action": "test"},
      "expectedStatus": 403,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "Access denied. Internal user required."}
    }
  ]
}