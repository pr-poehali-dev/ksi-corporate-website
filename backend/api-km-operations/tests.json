{
  "tests": [
    {
      "name": "OPTIONS returns CORS headers",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200,
      "bodyMatcher": "partial",
      "expectedBody": {}
    },
    {
      "name": "GET without auth returns 401",
      "method": "GET",
      "path": "/",
      "expectedStatus": 401,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "Unauthorized"}
    },
    {
      "name": "POST without auth returns 401",
      "method": "POST",
      "path": "/",
      "body": {"company_id": "test", "operation_type": "topup", "amount": 100},
      "expectedStatus": 401,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "Unauthorized"}
    }
  ]
}
