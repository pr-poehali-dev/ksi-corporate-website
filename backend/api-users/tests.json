{
  "tests": [
    {
      "name": "OPTIONS returns CORS headers",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200,
      "bodyMatcher": "partial",
      "expectedBody": {}
    },
    {
      "name": "GET without auth returns 401",
      "method": "GET",
      "path": "/",
      "expectedStatus": 401,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "Unauthorized"}
    },
    {
      "name": "POST without auth returns 401",
      "method": "POST",
      "path": "/",
      "body": {"email": "test@test.com", "password": "12345678", "full_name": "Test"},
      "expectedStatus": 401,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "Unauthorized"}
    }
  ]
}
